# Copy to .env.local for local development:
#   cp .env.example .env.local

# Your public site URL (used for sitemap + SEO)
NEXT_PUBLIC_SITE_URL="https://yourdomain.com"

# Database (Neon Postgres or local Docker — see docker-compose.yml)
DATABASE_URL="postgresql://pottery:pottery@localhost:5432/pottery"

# Auth (generate hash with: npm run hash-password -- "your-password")
# Important: escape every $ in the hash as \$ when pasting into .env.local
AUTH_SECRET=""
ADMIN_EMAIL="barnowlpottery@gmail.com"
ADMIN_PASSWORD_HASH=""

# Contact form — Resend (free tier: 100 emails/day)
# 1. Sign up at https://resend.com
# 2. Create an API key (Dashboard → API Keys)
# 3. Paste the key below and run: npm run check:email
# 4. Add the same key on Vercel: npx vercel env add RESEND_API_KEY
#
# Production (recommended for barnowlpottery.com):
# - Verify barnowlpottery.com at https://resend.com/domains
# - Contact form submissions are delivered to CONTACT_EMAIL below
RESEND_API_KEY=""
CONTACT_EMAIL="barnowlpottery@gmail.com"
EMAIL_FROM="Barn Owl Pottery <hello@barnowlpottery.com>"

# Cloudinary (for admin image uploads)
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
