{
  "name": "pottery-website",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20.9.0"
  },
  "scripts": {
    "predev": "node -e \"const m=process.version.match(/^v(\\d+)/);if(!m||+m[1]<20){console.error('\\nNode 20+ required (you have '+process.version+').\\nRun: source ~/.bashrc && nvm use\\n');process.exit(1)}\"",
    "dev": "next dev",
    "build": "node scripts/vercel-build.mjs",
    "start": "next start",
    "lint": "eslint",
    "postinstall": "prisma generate",
    "db:push": "dotenv -e .env.local -- prisma db push",
    "db:seed": "dotenv -e .env.local -- tsx prisma/seed.ts",
    "db:seed-gallery-courses": "tsx prisma/seed-gallery-courses.ts",
    "db:studio": "dotenv -e .env.local -- prisma studio",
    "hash-password": "tsx scripts/hash-password.ts",
    "check:email": "node scripts/check-email-config.mjs",
    "setup:resend": "node scripts/resend-setup-guide.mjs",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "bcryptjs": "^3.0.3",
    "cloudinary": "^2.10.0",
    "dotenv": "^17.4.2",
    "dotenv-cli": "^11.0.0",
    "next": "16.2.7",
    "next-auth": "^5.0.0-beta.31",
    "prisma": "^6.19.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "resend": "^6.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^4.7.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.7",
    "msw": "^2.14.6",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "typescript": "^5",
    "vitest": "^4.1.8"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
